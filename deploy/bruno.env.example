# /etc/bruno.env — production env for the systemd unit
# Copy to /etc/bruno.env, set chmod 0600 + chown root:bruno, edit values.
# This file is the sole place production secrets live on the host.

# === Production flags ===
# Disable dev-mode magic-link console logging; force real SMTP delivery
BRUNO_ADMIN_PROD=1
LENDER_PORTAL_PROD=1

# Disable Tier G admin auth on /borrower/* when an outer auth layer (e.g.
# Caddy basic-auth on app.rosimannus.ee) already protects the trading
# dashboard. The middleware is on by default; set =1 to skip it.
# Octoserver setup uses this because /borrower/* sits behind basic-auth already.
BRUNO_ADMIN_AUTH_DISABLE=1

# === Magic-link URL hosts (used in email bodies) ===
ADMIN_BASE_URL=https://mesicap.com
LENDER_BASE_URL=https://lender.mesicap.com

# === SMTP delivery ===
# Gmail-app-password example (cheapest path; requires 2FA on the gmail acct
# and an app password generated at https://myaccount.google.com/apppasswords):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mesicap.notifications@gmail.com
SMTP_PASS=replace-with-16-char-app-password
SMTP_FROM="MesiCap <mesicap.notifications@gmail.com>"
# SMTP_USE_SSL=1  # uncomment for port-465 implicit SSL instead of STARTTLS

# === Dead-man switch (governance.md §3.2) ===
DEADMAN_ENABLED=1
DEADMAN_WARNING_DAYS=30
DEADMAN_FREEZE_DAYS=37
# Designated executor surfaces on the freeze banner + receives the offline
# backup ledger if all 3 principals go quiet
DEADMAN_EXECUTOR_NAME="<full name>"
DEADMAN_EXECUTOR_EMAIL="<executor email>"

# === Access quorum (default 25000 if unset) ===
QUORUM_THRESHOLD_EUR=25000

# === Merit Aktiva API (governance.md §4.2) ===
# Live API pull runs only when cfg.app.bruno_run_integrations=true in
# config/settings.yaml (set there, not here)
MERIT_API_ID=
MERIT_API_KEY=
# Override if Merit ever moves the API base
# MERIT_API_BASE=https://aktiva.merit.ee/api/v2

# === E-sign providers (src/borrower/esign.py, Phase 2) ===
# Live signing runs only when cfg.app.bruno_run_integrations=true (clone).
# Dokobit — Estonian/Baltic eID (Smart-ID, Mobiil-ID, ID-card). Returns .asice.
DOKOBIT_API_TOKEN=
# DOKOBIT_BASE_URL=https://gateway.dokobit.com   # sandbox: gateway-sandbox.dokobit.com
# DocuSign — international eSignature (JWT grant). Returns signed PDF.
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi   # prod: https://www.docusign.net/restapi
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
# DOCUSIGN_PRIVATE_KEY=  # RSA private key (PEM) for JWT; or path via DOCUSIGN_PRIVATE_KEY_PATH

# === FX overrides (optional) ===
# Used for soft-threshold comparisons (e.g., quorum on non-EUR loans). Values
# are "1 unit of CURRENCY = N EUR". Falls back to a hardcoded dict if unset.
# FX_USD_TO_EUR=0.92
# FX_GBP_TO_EUR=1.17
# FX_AUD_TO_EUR=0.61
