# Caddy v2 reverse-proxy config for Bruno production on octoserver (37.0.30.34).
#
# Architecture: two independent FastAPI processes share the same bruno.db.
#   Process A — existing trading dashboard (Maggy/Winston + Bruno admin at /borrower/*).
#               Stays unchanged. Caddy doesn't need to know about it unless you
#               want to expose it on a public hostname (today: not).
#   Process B — dedicated lender portal (new). Runs on 127.0.0.1:8001 via
#               `deploy/bruno-lender.service`. Caddy serves it at
#               `lender.mesicap.com`.
#
# DNS A-records (confirmed 2026-05-20):
#   lender.mesicap.com  → 37.0.30.34
#   mesicap.com         → 37.0.30.34   (308-redirects to lender.mesicap.com)
#   mesicap.ee          → 37.0.30.34   (308-redirects to lender.mesicap.com)
#
# Install:
#   sudo cp deploy/Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#   curl -sI https://lender.mesicap.com/lenders/login   # → 200
#
# Caddy auto-issues Let's Encrypt certs for all three hostnames on first
# request. First-time cert issuance takes 10–30 seconds.

# === Apex + .ee redirects to lender portal ===
# Both mesicap.com and mesicap.ee 308-redirect to lender.mesicap.com (for now).
# Catches both root and any subpath: /foo → https://lender.mesicap.com/foo
mesicap.com, mesicap.ee {
    redir https://lender.mesicap.com{uri} permanent
}

# === Lender portal — dedicated process on port 8001 ===
lender.mesicap.com {
    encode gzip
    reverse_proxy 127.0.0.1:8001 {
        # Forward client metadata so the lender portal's audit_log records
        # the right values (not 127.0.0.1)
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    # Liveness probe — bypass logging
    @healthz path /healthz
    log_skip @healthz

    import secure_headers
}

# === Shared security-headers snippet ===
# governance.md §5.7 calls for CSP + HSTS + sane headers on lender-facing
# surface. Tailwind + Google Fonts CDNs are whitelisted; everything else is
# self-only.
(secure_headers) {
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.tailwindcss.com https://unpkg.com https://cdn.jsdelivr.net 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        X-Content-Type-Options "nosniff"
        Permissions-Policy "interest-cohort=(), browsing-topics=()"
        -Server
    }
}
